{
  "name": "@umituz/web-firebase",
  "version": "3.6.3",
  "description": "Comprehensive Firebase integration with domain-based architecture for web applications",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "firebase",
    "firestore",
    "auth",
    "storage",
    "functions",
    "analytics",
    "react",
    "web",
    "typescript",
    "ddd",
    "domain-driven-design",
    "package-driven",
    "repository-pattern"
  ],
  "author": "umituz",
  "license": "MIT",
  "peerDependencies": {
    "firebase": ">=12",
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "firebase": "^12.11.0",
    "typescript": "^5.0.0"
  }
}
