{
  "name": "@umituz/web-firebase",
  "version": "3.6.2",
  "description": "Comprehensive Firebase integration with domain-based architecture for web applications",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/domains/auth/index.ts",
    "./firestore": "./src/domains/firestore/index.ts",
    "./firestore/entities": "./src/domains/firestore/entities/index.ts",
    "./firestore/errors": "./src/domains/firestore/errors/index.ts",
    "./firestore/services": "./src/domains/firestore/services/index.ts",
    "./firestore/types": "./src/domains/firestore/types/index.ts",
    "./storage": "./src/domains/storage/index.ts",
    "./storage/entities": "./src/domains/storage/entities/index.ts",
    "./storage/services": "./src/domains/storage/services/index.ts",
    "./storage/types": "./src/domains/storage/types/index.ts",
    "./domain": "./src/domain/index.ts",
    "./config": "./src/domain/config/auth.config.ts",
    "./repository": "./src/infrastructure/services/firestore.repository.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "firebase",
    "firestore",
    "auth",
    "storage",
    "functions",
    "analytics",
    "react",
    "web",
    "typescript",
    "ddd",
    "domain-driven-design",
    "package-driven",
    "repository-pattern"
  ],
  "author": "umituz",
  "license": "MIT",
  "peerDependencies": {
    "firebase": ">=12",
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "firebase": "^12.11.0",
    "typescript": "^5.0.0"
  }
}
